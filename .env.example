# Server Configuration
PORT=3000

# MongoDB Configuration (MongoDB Atlas - Free Tier)
# Get your connection string from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/auth_db?retryWrites=true&w=majority

# JWT Secret (Create a random long string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email Configuration (Gmail)
# Follow: https://support.google.com/accounts/answer/185833
EMAIL_SERVICE=Gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM="ViceRide <noreply@viceride.com>"
